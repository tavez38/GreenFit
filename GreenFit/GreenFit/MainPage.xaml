<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GreenFit.MainPage"
             BackgroundColor="#F5F7F8"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

        <Label Text="Green Fit" 
               FontSize="44" 
               FontAttributes="Bold" 
               TextColor="#2D6A4F" 
               HorizontalOptions="Center" />

        <Image Source="logo_app.png" 
               HeightRequest="223" 
               WidthRequest="217"
               HorizontalOptions="Center" />

        <Label Text="Mappa le palestre all'aperto in tutto il mondo e unisciti alla nostra community di sportivi." 
               FontSize="16" 
               TextColor="#74C69D" 
               HorizontalTextAlignment="Center" 
               Margin="10,0,10,20" />

        <Frame BackgroundColor="#2D6A4F" 
               BorderColor="#74C69D" 
               Padding="10" 
               CornerRadius="10" 
               HasShadow="True"
               HeightRequest="60">

            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnGoogleLoginTapped" />
            </Frame.GestureRecognizers>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                <Image Source="google_icon.png" 
                       HeightRequest="25" 
                       VerticalOptions="Center" />

                <Label Text="Accedi con Google" 
                       VerticalOptions="Center" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       TextColor="#333333" />
            </HorizontalStackLayout>
        </Frame>

        <Label Text="Accedi come ospite" 
               FontSize="15" 
               TextColor="#2E7D32" 
               HorizontalOptions="Center" 
               TextDecorations="Underline"
               Margin="0,10,0,0">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnGuestLoginTapped" />
            </Label.GestureRecognizers>
        </Label>

    </VerticalStackLayout>
</ContentPage>