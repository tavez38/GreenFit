<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GreenFit.MainPage"
             NavigationPage.HasNavigationBar="False"> <!--Nasconderre barra per look full screen-->

    <Grid RowDefinitions="*, auto" Padding="30">
        <VerticalStackLayout Grid.Row="0"
                            VerticalOptions="Center"
                            Spacing="20">

        <Image Source="logo.png"
        HorizontalOptions="Center"
        HeightRequest="150" />

            <Label Text="Benvenuto in GreenFit!"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />

            <Label Text="L'app che trova la palestra all'aperto più vicina a te!"
               FontSize="18"
               TextColor="Gray"
               HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
        <VerticalStackLayout Grid.Row="1"
        Spacing="15">
            <Button Text="Accedi/Registrati con Google"
        ImageSource="google_icon.png"
        ContentLayout="Left,10"
        BackgroundColor="White"
        TextColor="Black"
        CornerRadius="25"
        HeightRequest="55"
        Shadow="{Shadow Brush=Black, Offset='0,5', Radius=5, Opacity=0.2}"
        Clicked="OnGoogleLoginClicked" />

            <Label Text="Accedendo accetti i termini di servizio" 
                   FontSize="12" 
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>



</ContentPage>
