<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GreenFit.Pages.ChatBotPage"
             BackgroundColor="#F5F7F8"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, *, Auto">

        <Grid Grid.Row="0" Padding="20,10" ColumnDefinitions="Auto, *, Auto">
            <Button Grid.Column="0" 
                   BackgroundColor="White"
                   Text="←" 
                   FontSize="18" 
                   TextColor="Gray" 
                   VerticalOptions="Center" 
                   Clicked="GoToGymDetails"/>
                   

            <Label Grid.Column="1" 
                   Text="GYM-BOT" 
                   FontSize="30" 
                   FontAttributes="Bold" 
                   TextColor="Green" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" />
        </Grid>

        <VerticalStackLayout Grid.Row="1" Padding="20,0" Spacing="10">
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Frame WidthRequest="40" HeightRequest="40" CornerRadius="5" Padding="0" BackgroundColor="#E0E0E0" HasShadow="False">
                    <Label Text="🏠" HorizontalOptions="Center" VerticalOptions="Center" FontSize="12"/>
                </Frame>
                <Label x:Name="NameGym"
                 FontSize="14" VerticalOptions="Center" TextColor="Black"
                />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="#EEEEEE" HorizontalOptions="Fill" />

            <Label Text="Descrivi che cosa vorresti allenare e io ti fornirò una scheda per te" 
                   FontAttributes="Bold" 
                   FontSize="18" 
                   TextColor="Black" 
                   Margin="0,10,0,5" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="2" Padding="20">
            <VerticalStackLayout Spacing="20">

                <VerticalStackLayout Spacing="10">
                    <Label Text="Suggerimenti:" FontSize="12" TextColor="Gray"/>

                    <Frame BackgroundColor="White" CornerRadius="10" HasShadow="True" Padding="15">
                        <Label Text="Voglio un allenamento per le spalle di 45 minuti" FontSize="14" TextColor="#333333"/>
                    </Frame>

                    <Frame BackgroundColor="White" CornerRadius="10" HasShadow="True" Padding="15">
                        <Label Text="Crea una scheda full-body per principianti" FontSize="14" TextColor="#333333"/>
                    </Frame>

                    <Frame BackgroundColor="White" CornerRadius="10" HasShadow="True" Padding="15">
                        <Label Text="Allenamento cardio ad alta intensità" FontSize="14" TextColor="#333333"/>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="15" Margin="0,10">
                    <Frame BackgroundColor="#F1F8E9" CornerRadius="15" BorderColor="Transparent" HorizontalOptions="Start">
                        <Label x:Name="responseBot" TextColor="Black"/>
                    </Frame>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="3" 
              ColumnDefinitions="*, Auto" 
              Padding="20,10,20,30" 
              BackgroundColor="White" 
              ColumnSpacing="10">

            <Frame Grid.Column="0" 
                   Padding="10,0" 
                   HeightRequest="50" 
                   CornerRadius="25" 
                   BorderColor="#CCCCCC" 
                   BackgroundColor="#F9F9F9" 
                   HasShadow="False">
                <Entry x:Name="Prompt"
                Placeholder="Scrivi il tuo prompt qui..." 
                       VerticalOptions="Center" 
                       TextColor="Black" 
                       PlaceholderColor="Gray"/>
            </Frame>

            <Button Grid.Column="1" 
                    Text="➤" 
                    BackgroundColor="Green" 
                    TextColor="White" 
                    CornerRadius="25" 
                    WidthRequest="50" 
                    HeightRequest="50"
                    Clicked="SendAIRequest"/>
        </Grid>

    </Grid>
</ContentPage>