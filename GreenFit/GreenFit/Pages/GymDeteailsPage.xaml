<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GreenFit.Pages.GymDeteailsPage"
             Title="GymDeteailsPage"
             BackgroundColor="#F5F7F8"
             Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <Image x:Name="imgGymTag" 
            Source="palestra_foto.jpg" 
                   HeightRequest="220" 
                   Aspect="AspectFill" />

            <Label x:Name="gymNameLabel" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#222222" />

            <Button Text="Portami là"
                BackgroundColor="#FF9F1C" 
                TextColor="#1B4332" 
                CornerRadius="20" 
                HeightRequest="40"
                Clicked="openMaps"/>
            
            <Button Text="Aggiungi recensione"
                BackgroundColor="#FF9F1C" 
                TextColor="#1B4332" 
                CornerRadius="20" 
                HeightRequest="40"
                Clicked="addRecensione"/>

            <BoxView HeightRequest="1" Color="#DDDDDD" Margin="0,10,0,10" />

            <Label x:Name="IntroRecensioni"
                   FontSize="20" 
                   FontAttributes="Bold" 
                   TextColor="#222222" />

            <HorizontalStackLayout x:Name="StarLayout" Spacing="2" HorizontalOptions="Start">
                <Label Text="★" FontSize="24" TextColor="#CCCCCC" />
                <Label Text="★" FontSize="24" TextColor="#CCCCCC" />
                <Label Text="★" FontSize="24" TextColor="#CCCCCC" />
                <Label Text="★" FontSize="24" TextColor="#CCCCCC" />
                <Label Text="★" FontSize="24" TextColor="#CCCCCC" />

                <Label x:Name="MediaVotoLabel" 
               VerticalOptions="Center" 
               Margin="10,0,0,0" 
               FontSize="16" 
               TextColor="#666666" />
            </HorizontalStackLayout>

            <VerticalStackLayout x:Name="ListaRecensioni" Spacing="10" Padding="20" />

            <Button Text="Crea il tuo allenamento" 
                HorizontalOptions="EndAndExpand" 
                BackgroundColor="#FF9F1C" 
                TextColor="#1B4332" 
                CornerRadius="20" 
                HeightRequest="40"
                Clicked="goToChatBot"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>